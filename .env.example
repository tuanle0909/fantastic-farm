# Copy to `.env` locally. On Vercel/Netlify set each `VITE_*` in the dashboard (build-time).

# Backend API — production example:
# VITE_BE_API_URL=https://fantastic-farm-api.onrender.com/api
VITE_BE_API_URL=http://localhost:8000/api

VITE_REQUIRED_SUI_CHAIN=sui:testnet
VITE_SUI_NETWORK=testnet
VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
VITE_SLUSH_WALLET_ORIGIN=https://slush.app
VITE_PREFERRED_WALLET=Slush

# Unity WebGL files served under this path (see DEPLOY.md).
VITE_UNITY_BUILD_BASE_URL=/unity

# On-chain IDs — MUST match backend after `sui client publish` (same package).
VITE_FANTASTIC_FARM_PACKAGE_ID=0xYOUR_PACKAGE_ID
VITE_FANTASTIC_FARM_REGISTRY_OBJECT_ID=0xYOUR_FARM_REGISTRY_ID
VITE_FANTASTIC_FARM_MARKETPLACE_OBJECT_ID=0xYOUR_MARKETPLACE_ID
VITE_FANTASTIC_FARM_FC_MINT_REGISTRY_OBJECT_ID=0xYOUR_FC_MINT_REGISTRY_ID
